[Unit]
Description=Whisper PTT dictation daemon (HTTP backend)
After=graphical-session.target whisper-server.service
Requires=whisper-server.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /usr/local/bin/whisper-ptt
Restart=on-failure
RestartSec=3
Environment=XDG_RUNTIME_DIR=/run/user/1000

[Install]
WantedBy=graphical-session.target
