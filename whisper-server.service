[Unit]
Description=Whisper HTTP inference server (model stays loaded in VRAM)
After=graphical-session.target

[Service]
Type=simple
ExecStart=/home/pokr/whisper.cpp/build/bin/whisper-server \
    -m /home/pokr/whisper.cpp/models/ggml-large-v3-turbo.bin \
    -l auto \
    --host 127.0.0.1 \
    --port 9001 \
    -t 4
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
